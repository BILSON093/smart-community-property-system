/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  /* 深蓝灰色渐变背景 */
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
}

.login-box {
  width: 100%;
  max-width: 840rpx;
}

.login-header {
  text-align: center;
  margin-bottom: 80rpx;
}

.header-icon {
  display: block;
  font-size: 128rpx;
  color: #4F6EF7;
  margin-bottom: 32rpx;
}

.title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #dee7f3;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #94A3B8;
  margin: 0;
}

.login-form {
  background: white;
  border-radius: 48rpx;
  padding: 80rpx 64rpx;
  box-shadow: 0 40rpx 120rpx rgba(0, 0, 0, 0.4);
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 40rpx;
  position: relative;
}

.form-item:last-of-type {
  margin-bottom: 60rpx;
}

.label {
  font-size: 28rpx;
  color: #64748B;
  width: 140rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1E293B;
}

.placeholder {
  color: #c0c4cc;
}

.eye-icon {
  font-size: 32rpx;
  margin-left: 20rpx;
  color: #94A3B8;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
}

/* 角色选择器 */
.role-selector {
  display: flex;
  gap: 20rpx;
  flex: 1;
}

.role-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F1F5F9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #64748B;
  transition: all 0.3s;
}

.role-item.active {
  background: #4F6EF7;
  color: #fff;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  margin-top: 64rpx;
  border: none;
  transition: opacity 0.3s;
  box-shadow: 0 8rpx 24rpx rgba(79, 110, 247, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-login:active {
  opacity: 0.9;
}

.btn-login::after {
  border: none;
}

.register-link {
  text-align: center;
  color: #4F6EF7;
  font-size: 28rpx;
  margin-top: 32rpx;
  padding-top: 16rpx;
  opacity: 0.9;
}

.login-tips {
  text-align: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #94A3B8;
}
