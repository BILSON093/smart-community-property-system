/* pages/repairer-home/repairer-home.wxss */
.container {
  min-height: 100vh;
  background-color: #F7F8FB;
  padding-bottom: 20rpx;
}

/* 自定义导航栏 */
.custom-nav-bar {
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  padding-top: calc(160rpx + env(safe-area-inset-top));
  padding-bottom: 20rpx;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  height: 88rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.refresh-btn {
  font-size: 28rpx;
  color: #fff;
  opacity: 0.9;
  padding: 10rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
}

.logout {
  font-size: 28rpx;
  color: #fff;
  opacity: 0.9;
  padding: 10rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

/* 统计卡片 */
.stats-container {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 30rpx;
  background-color: #fff;
  margin: 60rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #4F6EF7;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #94A3B8;
}

/* 标签页 */
.tabs {
  display: flex;
  background-color: #fff;
  margin: 0 20rpx 40rpx 20rpx;
  border-bottom: 1rpx solid #F1F5F9;
  border-radius: 16rpx 16rpx 0 0;
  padding-top: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 35rpx 0;
  font-size: 28rpx;
  color: #64748B;
  position: relative;
}

.tab-item.active {
  color: #4F6EF7;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #4F6EF7;
  border-radius: 2rpx;
}

/* 工单列表 */
.order-list {
  padding: 0 20rpx 40rpx 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 26rpx;
  color: #94A3B8;
}

.order-status {
  font-size: 24rpx;
  color: #4F6EF7;
  background-color: rgba(79, 110, 247, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.order-content {
  margin-bottom: 20rpx;
}

.order-desc {
  display: block;
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.arrow {
  font-size: 32rpx;
  color: #CBD5E1;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}
