/* pages/repair-detail/repair-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.detail-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.status-bar {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-0 {
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
}

.status-1 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-2 {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.status-3 {
  background: linear-gradient(135deg, #00c853 0%, #009624 100%);
}

.status-4 {
  background: linear-gradient(135deg, #9e9e9e 0%, #757575 100%);
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.status-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section {
  padding: 30rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.section:last-child {
  border-bottom: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #969799;
  flex-shrink: 0;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
}

.value.rating {
  color: #ff9800;
}

.images-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.detail-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.actions {
  padding: 30rpx;
}

.btn-evaluate {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-evaluate::after {
  border: none;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #969799;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #969799;
  font-size: 28rpx;
}

/* 评价弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  animation: modalShow 0.3s ease;
}

@keyframes modalShow {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.modal-close {
  font-size: 48rpx;
  color: #969799;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.rate-section {
  margin-bottom: 30rpx;
}

.rate-label {
  display: block;
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 20rpx;
}

.rate-stars {
  display: flex;
  gap: 16rpx;
}

.star {
  font-size: 64rpx;
  color: #cccccc;
  opacity: 0.5;
  cursor: pointer;
  transition: color 0.2s, opacity 0.2s;
}

.star.active {
  color: #ff9800;
  opacity: 1;
}

.comment-section {
  margin-bottom: 30rpx;
}

.comment-label {
  display: block;
  font-size: 28rpx;
  color: #323233;
  margin-bottom: 16rpx;
}

.comment-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  border: none;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #ebedf0;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #f7f8fa;
  color: #323233;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
}

.btn-submit::after {
  border: none;
}
