/* pages/news-detail/news-detail.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
  background-color: #F7F8FB;
}

.notice-detail {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notice-header {
  border-bottom: 1rpx solid #F1F5F9;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.notice-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.notice-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
}

.notice-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background-color: #F8FAFC;
  color: #94A3B8;
  margin-left: 16rpx;
}

.notice-tag.important {
  background-color: #fff7e6;
  color: #d97706;
}

.notice-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.notice-content {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.8;
}

.image-list {
  margin-top: 20rpx;
}

.notice-image {
  width: 100%;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

/* 附件样式 */
.attachment-list {
  margin-top: 30rpx;
  padding: 24rpx;
  background-color: #F8FAFC;
  border-radius: 16rpx;
}

.attachment-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 20rpx;
}

.attachment-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.attachment-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.attachment-icon {
  font-size: 28rpx;
  color: #4F6EF7;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.attachment-name {
  flex: 1;
  font-size: 26rpx;
  color: #1E293B;
  line-height: 1.4;
}

.download-icon {
  font-size: 28rpx;
  color: #94A3B8;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #94A3B8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}
