/* pages/edit-profile/edit-profile.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 20rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.avatar-item {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.label {
  width: 160rpx;
  font-size: 30rpx;
  color: #323233;
  font-weight: 500;
  flex-shrink: 0;
}

.input {
  flex: 1;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #323233;
}

.input[disabled] {
  background-color: #f0f0f0;
  color: #969799;
}

.avatar-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.change-text {
  font-size: 26rpx;
  color: #1989fa;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin: 40rpx 0 20rpx 0;
}

.address-row {
  display: flex;
  gap: 20rpx;
}

.form-item.small {
  flex: 1;
}

.form-item.small .label {
  width: 100rpx;
}

.btnSave {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
  border: none;
  font-weight: bold;
}

.btn-save::after {
  border: none;
}
