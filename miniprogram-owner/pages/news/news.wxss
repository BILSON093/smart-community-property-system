/* pages/news/news.wxss */
.container {
  min-height: 100vh;
  padding: 20rpx;
}

.notice-list {
  padding-bottom: 40rpx;
}

.notice-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notice-header {
  border-bottom: 1rpx solid #F1F5F9;
  padding-bottom: 20rpx;
}

.notice-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.notice-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background-color: #F8FAFC;
  color: #94A3B8;
  margin-left: 16rpx;
}

.notice-tag.important {
  background-color: #fff7e6;
  color: #d97706;
}

.notice-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #94A3B8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}
