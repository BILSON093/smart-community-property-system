/* pages/notification/notification.wxss */
.container {
  padding: 20rpx;
  background: #F7F8FB;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.unread-text {
  font-size: 28rpx;
  color: #64748B;
}

.read-all-btn {
  font-size: 28rpx;
  color: #4F6EF7;
  cursor: pointer;
}

.notification-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
  transition: all 0.3s;
}

.notification-item.unread {
  background: rgba(79, 110, 247, 0.06);
  border-left: 6rpx solid #4F6EF7;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  flex: 1;
  margin-right: 16rpx;
}

.item-time {
  font-size: 24rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.item-body {
  margin-bottom: 8rpx;
}

.item-content {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #EF4444;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}
