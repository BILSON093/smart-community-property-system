<!--pages/notification/notification.wxml-->
<view class="container">
  <view class="header" wx:if="{{notifications.length > 0}}">
    <text class="unread-text">{{unreadCount}} 条未读消息</text>
    <text class="read-all-btn" bindtap="markAllRead">全部已读</text>
  </view>

  <view class="notification-list">
    <view
      class="notification-item {{item.isRead === 0 ? 'unread' : ''}}"
      wx:for="{{notifications}}"
      wx:key="id"
      bindtap="markRead"
      data-id="{{item.id}}"
      data-index="{{index}}"
    >
      <view class="item-header">
        <text class="item-title">{{item.title}}</text>
        <text class="item-time">{{item.createTime}}</text>
      </view>
      <view class="item-body">
        <text class="item-content">{{item.content}}</text>
      </view>
      <view class="unread-dot" wx:if="{{item.isRead === 0}}"></view>
    </view>

    <view class="empty" wx:if="{{loading === false && notifications.length === 0}}">
      <text class="empty-icon">🔔</text>
      <text class="empty-text">暂无消息通知</text>
    </view>

    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
