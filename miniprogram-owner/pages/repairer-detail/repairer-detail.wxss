/* pages/repairer-detail/repairer-detail.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 180rpx;
}

/* 状态栏 */
.status-bar {
  padding: 40rpx 30rpx;
  text-align: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.status-bar.pending {
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
}

.status-bar.in-progress {
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
}

.status-bar.completed {
  background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
}

/* 卡片样式 */
.card {
  background-color: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1E293B;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.label {
  font-size: 28rpx;
  color: #94A3B8;
  width: 180rpx;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #1E293B;
  text-align: right;
  flex: 1;
}

.value.phone {
  color: #4F6EF7;
}

.detail-content {
  font-size: 28rpx;
  color: #64748B;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

/* 图片展示 */
.images {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

/* 操作按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-start {
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #fff;
}

.btn-complete {
  background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
  color: #fff;
}

.btn-cancel {
  background-color: #fff;
  color: #F59E0B;
  border: 2rpx solid #F59E0B;
}
