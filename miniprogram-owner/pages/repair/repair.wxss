/* pages/repair/repair.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

/* 报修记录区域 */
.repair-list-section {
  background-color: #ffffff;
}

.section-header {
  padding: 30rpx 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.tab-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 30rpx 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #646566;
  padding: 16rpx 0;
  position: relative;
}

.tab-item.active {
  color: #304156;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #304156;
  border-radius: 2rpx;
}

.repair-list {
  padding: 0 20rpx 20rpx;
}

.repair-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #323233;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-0 {
  background-color: #fff7e6;
  color: #d97706;
}

.status-1 {
  background-color: #f0f5ff;
  color: #304156;
}

.status-2 {
  background-color: #f0f5ff;
  color: #304156;
}

.status-3 {
  background-color: #f0fdf4;
  color: #16a34a;
}

.status-4 {
  background-color: #f5f5f5;
  color: #969799;
}

.card-content {
  margin-bottom: 20rpx;
}

.content-text {
  font-size: 28rpx;
  color: #646566;
  line-height: 1.6;
}

.card-images {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.repair-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebedf0;
}

.time {
  font-size: 24rpx;
  color: #969799;
}

.worker {
  font-size: 26rpx;
  color: #304156;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #969799;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #969799;
  font-size: 28rpx;
}

/* 添加按钮 */
.add-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #304156 0%, #3a4b63 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(48, 65, 86, 0.4);
  z-index: 999;
}

.add-icon {
  font-size: 72rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 650rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  animation: modalShow 0.3s ease;
}

@keyframes modalShow {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #ebedf0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.modal-close {
  font-size: 48rpx;
  color: #969799;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #323233;
  margin-bottom: 16rpx;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  border: none;
  box-sizing: border-box;
  color: #323233;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #969799;
  margin-top: 8rpx;
}

/* 图片上传 */
.uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.file-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.file-preview {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.file-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  border-radius: 0 8rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.upload-area {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #dcdfe6;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f7f8fa;
}

.upload-icon {
  font-size: 48rpx;
  color: #c0c4cc;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 22rpx;
  color: #909399;
}

.upload-tip {
  display: block;
  font-size: 24rpx;
  color: #969799;
  margin-top: 12rpx;
}

/* 分类选择器 */
.picker-value {
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  color: #323233;
  min-height: 40rpx;
  line-height: 40rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #ebedf0;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #f7f8fa;
  color: #323233;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-cancel::after {
  border: none;
}

.btn-submit {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #304156 0%, #3a4b63 100%);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-submit::after {
  border: none;
}

.btn-submit[disabled] {
  opacity: 0.6;
}

