/* pages/feedback/feedback.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.feedback-list {
  margin-bottom: 40rpx;
  max-height: 800rpx;
  overflow-y: auto;
}

.feedback-card {
  background-color: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
}

.status-0 {
  background-color: #fff7e6;
  color: #d97706;
}

.status-1 {
  background-color: #f0fdf4;
  color: #16a34a;
}

.time {
  font-size: 24rpx;
  color: #969799;
}

.card-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  color: #323233;
  line-height: 1.6;
}

.card-reply {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  border-left: 4rpx solid #304156;
}

.reply-title {
  font-size: 26rpx;
  color: #304156;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.reply-text {
  font-size: 26rpx;
  color: #646566;
  line-height: 1.6;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #969799;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #969799;
  font-size: 28rpx;
}

.input-section {
  border-top: 1rpx solid #ebedf0;
  padding-top: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
  margin-bottom: 20rpx;
}

.feedback-input {
  width: 100%;
  min-height: 200rpx;
  background-color: #f7f8fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #323233;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #969799;
  margin-top: 12rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #304156 0%, #3a4b63 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 30rpx;
  border: none;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-submit::after {
  border: none;
}
