/* pages/feedback/feedback.wxss */
.container {
  min-height: 100vh;
  background-color: #F7F8FB;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.feedback-list {
  margin-bottom: 40rpx;
  max-height: 800rpx;
  overflow-y: auto;
}

.feedback-card {
  background-color: #F8FAFC;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-0 {
  background-color: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.status-1 {
  background-color: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.time {
  font-size: 24rpx;
  color: #94A3B8;
}

.card-content {
  margin-bottom: 16rpx;
}

.content-text {
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.6;
}

.card-reply {
  background-color: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  border-left: 4rpx solid #4F6EF7;
}

.reply-title {
  font-size: 26rpx;
  color: #4F6EF7;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.reply-text {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #94A3B8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #969799;
  font-size: 28rpx;
}

.input-section {
  border-top: 1rpx solid #F1F5F9;
  padding-top: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.feedback-input {
  width: 100%;
  min-height: 200rpx;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1E293B;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 30rpx;
  border: none;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-submit::after {
  border: none;
}
