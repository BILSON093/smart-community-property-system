/* pages/pay/pay.wxss */
.container {
  min-height: 100vh;
  background-color: #F7F8FB;
  padding-bottom: 40rpx;
}

.stat-card {
  display: flex;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  padding: 40rpx 30rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.3);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
}

.stat-value.unpaid {
  color: #ffd700;
}

.stat-value.paid {
  color: #ffffff;
}

.divider {
  width: 1rpx;
  background-color: rgba(255, 255, 255, 0.3);
  margin: 0 40rpx;
}

.filter-bar {
  display: flex;
  padding: 20rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.filter-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #64748B;
  padding: 16rpx 0;
  position: relative;
}

.filter-item.active {
  color: #4F6EF7;
  font-weight: 600;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #4F6EF7;
  border-radius: 2rpx;
}

.fee-list {
  padding: 20rpx;
}

.fee-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.fee-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-0 {
  background-color: rgba(245, 158, 11, 0.1);
  color: #F59E0B;
}

.status-1 {
  background-color: rgba(16, 185, 129, 0.1);
  color: #10B981;
}

.card-content {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #94A3B8;
}

.value {
  font-size: 26rpx;
  color: #1E293B;
}

.value.amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #EF4444;
}

.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}

.btn-pay {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-pay::after {
  border: none;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #94A3B8;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 28rpx;
}

/* 支付弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 650rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalShow 0.3s ease;
}

@keyframes modalShow {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.modal-close {
  font-size: 48rpx;
  color: #94A3B8;
  line-height: 1;
  padding: 0 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.payment-summary {
  margin-bottom: 30rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.summary-item {
  display: flex;
  margin-bottom: 16rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #94A3B8;
  width: 140rpx;
  flex-shrink: 0;
}

.summary-value {
  font-size: 26rpx;
  color: #1E293B;
  flex: 1;
}

.summary-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #EF4444;
}

.payment-methods {
  margin-bottom: 20rpx;
}

.method-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
  display: block;
}

.method-list {
  display: flex;
  gap: 16rpx;
}

.method-item {
  flex: 1;
  border: 2rpx solid #E2E8F0;
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.method-item.selected {
  border-color: #4F6EF7;
  background-color: rgba(79, 110, 247, 0.06);
}

.method-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}

.method-name {
  font-size: 22rpx;
  color: #64748B;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #F1F5F9;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #F8FAFC;
  color: #64748B;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-confirm::after {
  border: none;
}

