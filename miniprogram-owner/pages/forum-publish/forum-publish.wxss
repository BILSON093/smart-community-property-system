/* pages/forum-publish/forum-publish.wxss */
.container {
  min-height: 100vh;
  background-color: #F7F8FB;
  padding: 20rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #1E293B;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1E293B;
}

.title-input {
  font-size: 32rpx;
  font-weight: 500;
}

.picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
}

.picker text:first-child {
  flex: 1;
  font-size: 30rpx;
  color: #1E293B;
}

.placeholder {
  color: #94A3B8;
}

.arrow {
  color: #94A3B8;
  font-size: 24rpx;
}

.content-item {
  position: relative;
}

.textarea {
  width: 100%;
  min-height: 300rpx;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #1E293B;
  line-height: 1.8;
}

.char-count {
  position: absolute;
  bottom: 30rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #94A3B8;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  line-height: 1;
}

.add-image {
  width: 200rpx;
  height: 200rpx;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #E2E8F0;
}

.add-icon {
  font-size: 48rpx;
  color: #94A3B8;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: #94A3B8;
}

.switch-wrapper {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
}

.switch-label {
  font-size: 30rpx;
  color: #1E293B;
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-top: 40rpx;
  border: none;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.btn-submit::after {
  border: none;
}
