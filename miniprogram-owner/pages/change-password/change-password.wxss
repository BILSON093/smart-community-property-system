/* pages/change-password/change-password.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 40rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.form-item {
  border-bottom: 1px solid #eeeeee;
  padding: 30rpx 0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  font-size: 30rpx;
  color: #333333;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #304156 0%, #3a4b63 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(48, 65, 86, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
