/* pages/change-password/change-password.wxss */
.container {
  min-height: 100vh;
  background-color: #F7F8FB;
  padding: 40rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.form-item {
  border-bottom: 1px solid #F1F5F9;
  padding: 30rpx 0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #1E293B;
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  font-size: 30rpx;
  color: #1E293B;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #4F6EF7 0%, #6B85F9 100%);
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(79, 110, 247, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
