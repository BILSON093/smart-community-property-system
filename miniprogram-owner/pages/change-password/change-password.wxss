/* pages/change-password/change-password.wxss */
.container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding: 40rpx;
}

.form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.form-item {
  border-bottom: 1px solid #eeeeee;
  padding: 30rpx 0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  font-size: 30rpx;
  color: #333333;
}

.btn-submit {
  margin-top: 60rpx;
  background-color: #1989fa;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 12rpx;
}
