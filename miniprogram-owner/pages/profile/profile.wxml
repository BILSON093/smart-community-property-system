<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 未登录状态 -->
  <view class="not-login" wx:if="{{!userInfo}}">
    <view class="login-card">
      <text class="welcome-text">欢迎使用智慧社区</text>
      <text class="desc-text">请登录后使用完整功能</text>
      <button class="btn-login" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="logged-in" wx:else>
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatar || '/images/avatar-default.png'}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="username">{{userInfo.realName || userInfo.username}}</text>
        <text class="phone">{{userInfo.phone}}</text>
      </view>
      <view class="edit-btn" bindtap="goToEditProfile">
        <text>编辑</text>
      </view>
    </view>

    <!-- 地址信息 -->
    <view class="address-card">
      <text class="section-title">我的地址</text>
      <view class="address-info">
        <text class="address-text">{{userInfo.building}} {{userInfo.unit}} {{userInfo.room}}</text>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="goToRepair">
        <view class="menu-left">
          <text class="menu-icon">🔧</text>
          <text class="menu-text">我的报修</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToPay">
        <view class="menu-left">
          <text class="menu-icon">💳</text>
          <text class="menu-text">我的缴费</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToForum">
        <view class="menu-left">
          <text class="menu-icon">💬</text>
          <text class="menu-text">我的帖子</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item" bindtap="goToFeedback">
        <view class="menu-left">
          <text class="menu-icon">💭</text>
          <text class="menu-text">我的留言</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>

    <!-- 设置菜单 -->
    <view class="menu-list">
      <view class="menu-item" bindtap="changePassword">
        <view class="menu-left">
          <text class="menu-icon">🔐</text>
          <text class="menu-text">修改密码</text>
        </view>
        <text class="arrow">></text>
      </view>

      <view class="menu-item logout" bindtap="logout">
        <view class="menu-left">
          <text class="menu-icon">🚪</text>
          <text class="menu-text">退出登录</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>
</view>
